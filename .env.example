# ---------------------------------------------------------------------------
# Hebron Coding Hackathon — environment template
# Copy this file to `.env` and fill in the values before running docker compose.
# ---------------------------------------------------------------------------

# Environment: "development" (default) or "production".
# In production, the backend refuses to start if any REQUIRED value below is missing.
ENV=development

# JWT signing secret — REQUIRED.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-me

# JWT token lifetime in minutes. 1440 = 24h.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Password for the bootstrap admin account. Only used on a fresh database.
# REQUIRED in production; optional in development (falls back to the weak
# default documented in the README). Judges are created via the admin panel;
# teams register themselves through the public registration form.
ADMIN_PASSWORD=

# Comma-separated list of allowed frontend origins for CORS.
# Use "*" for development/LAN (allows any origin without credentials).
# REQUIRED to be explicit in production, e.g.:
#   CORS_ORIGINS=https://hackathon.example.com
CORS_ORIGINS=*

# Optional Discord webhook URL. If set, the backend posts a message to this
# webhook whenever an unhandled exception escapes a request handler. Leave
# empty to disable. Create one in Discord via
# Server settings → Integrations → Webhooks → New Webhook.
DISCORD_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Caddy reverse proxy — public domain for automatic HTTPS.
#
# In production set this to your domain, e.g.:
#   HACKATHON_DOMAIN=hackathon.example.com
# On first boot Caddy will negotiate a Let's Encrypt cert automatically.
#
# For local dev without a domain, leave it as ":80" and Caddy will listen
# on http://localhost without TLS.
# ---------------------------------------------------------------------------
HACKATHON_DOMAIN=:80

# ---------------------------------------------------------------------------
# Frontend — used at Vite build time by docker compose. These are baked into
# the static bundle, so rebuild the frontend image after changing them.
#
# VITE_API_ENDPOINT:
#   - Leave EMPTY in production behind the Caddy reverse proxy. The frontend
#     will make same-origin requests like /api/... which Caddy routes to the
#     backend container. This is the recommended setup.
#   - Set to "http://localhost:8000" for raw local development without Caddy.
# ---------------------------------------------------------------------------
VITE_API_ENDPOINT=
VITE_USE_MOCK_DATA=false
